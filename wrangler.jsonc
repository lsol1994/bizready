{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "bizready",
  "compatibility_date": "2026-03-20",
  "pages_build_output_dir": "./dist",
  "compatibility_flags": [
    "nodejs_compat"
  ]
  // 환경변수는 Cloudflare Pages Secret으로 관리 (wrangler pages secret put)
  // SUPABASE_URL, SUPABASE_ANON_KEY, SUPABASE_SERVICE_ROLE_KEY
  // PORTONE_V2_STORE_ID, PORTONE_V2_CHANNEL_KEY_KAKAO, PORTONE_V2_CHANNEL_KEY_TOSS, PORTONE_V2_API_SECRET
}
