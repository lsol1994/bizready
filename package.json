{
  "name": "webapp",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "NODE_ENV=production node --max-old-space-size=4096 node_modules/.bin/vite build && node -e \"const fs=require('fs');fs.writeFileSync('dist/_routes.json',JSON.stringify({version:1,include:['/*'],exclude:['/static/*','/favicon.svg','/favicon.ico']}))\""  ,
    "preview": "wrangler pages dev",
    "deploy": "npm run build && wrangler pages deploy",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings",
    "post-deploy": "python3 scripts/post-deploy.py"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.99.3",
    "hono": "^4.12.8"
  },
  "devDependencies": {
    "@hono/vite-build": "^1.2.0",
    "@hono/vite-dev-server": "^0.18.2",
    "vite": "^6.3.5",
    "wrangler": "^4.4.0"
  }
}
