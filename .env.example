# BizReady 환경 변수 설정 파일
# 이 파일을 .dev.vars 로 복사 후 실제 값을 채워주세요
# .dev.vars 는 절대 git에 커밋하지 마세요!

# ── Supabase ────────────────────────────────────────────────
# Supabase Dashboard → Settings → API 에서 확인
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxx          # 브라우저 노출 허용 (anon/publishable)
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxxxxxxxxx        # ❌ 서버사이드 전용 (절대 노출 금지)

# ── 포트원 V2 ──────────────────────────────────────────────
# https://admin.portone.io → 상점·계정 관리 → API Keys
PORTONE_V2_STORE_ID=store-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# 채널 관리 → 카카오페이 채널 클릭 → Channel Key
PORTONE_V2_CHANNEL_KEY_KAKAO=channel-key-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# 채널 관리 → 토스페이먼츠 채널 클릭 → Channel Key
PORTONE_V2_CHANNEL_KEY_TOSS=channel-key-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# V2 API Secret (절대 노출 금지)
PORTONE_V2_API_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx  # ❌ 서버사이드 전용
